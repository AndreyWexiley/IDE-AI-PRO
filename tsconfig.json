{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@ai/*": ["./src/ai/*"],
      "@agent/*": ["./src/agent/*"],
      "@rag/*": ["./src/rag/*"],
      "@executor/*": ["./src/executor/*"],
      "@parser/*": ["./src/parser/*"],
      "@memory/*": ["./src/memory/*"],
      "@logger/*": ["./src/logger/*"],
      "@api/*": ["./src/api/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
