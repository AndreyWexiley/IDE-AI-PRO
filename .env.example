# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Workspace ────────────────────────────────────────────────────────────────
WORKSPACE_PATH=./workspace

# ─── Model Tiers (optional — defaults shown) ─────────────────────────────────
MODEL_SIMPLE=gpt-4o-mini
MODEL_MEDIUM=gpt-4o
MODEL_COMPLEX=claude-3-5-sonnet-20241022

# ─── Ollama (offline AI — optional) ──────────────────────────────────────────
# Path to ollama.exe — leave empty to auto-detect from PATH or common locations
# OLLAMA_EXE_PATH=C:\Program Files\Ollama\ollama.exe

# Path where Ollama stores models — leave empty to use system default (~/.ollama/models)
# OLLAMA_MODELS=C:\Users\YourName\.ollama\models

# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Server (API mode) ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
