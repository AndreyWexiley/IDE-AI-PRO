{
  "name": "ai-engineering-system",
  "version": "1.0.0",
  "description": "AI-assisted engineering system inspired by Cursor IDE",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --runInBand",
    "test:run": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=unit --runInBand --forceExit",
    "test:properties": "jest --testPathPattern=properties --runInBand --forceExit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "engineering",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "uuid": "^11.1.0"
  }
}
